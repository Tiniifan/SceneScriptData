{
  "name": "ssd-toolchain",
  "version": "0.1.0",
  "description": "SSD binary script file toolchain: reader, AST builder, JSON export, SVG image export, and AST→SSD/SST compiler",
  "main": "dist/index.js",
  "files": [
    "dist",
    "package.json"
  ],
  "bin": {
    "ssd": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc && copyfiles -u 1 \"src/**/*.yml\" dist",
    "dev": "ts-node src/cli.ts",
    "start": "node dist/cli.js"
  },
  "dependencies": {
    "commander": "^11.1.0",
    "iconv-lite": "^0.7.2",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "copyfiles": "^2.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0"
  }
}
